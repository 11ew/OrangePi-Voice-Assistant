{
  "vad": {
    "enabled": true,
    "config_file": "config/vad_config.json"
  },
  "asr": {
    "config_file": "config/asr_config.json",
    "model_type": "paraformer",
    "use_streaming": true,
    "num_threads": 4
  },
  "llm": {
    "api_key": "YOUR_DEEPSEEK_API_KEY",
    "api_base": "https://api.deepseek.com/v1",
    "model": "deepseek-chat",
    "timeout": 10,
    "max_retries": 3,
    "max_tokens": 50,
    "system_prompt": "你是哈雷酱，俏皮可爱的语音助手。说话自然亲切，多用「呀」「哦」「呢」「啦」等语气词。回复超简短（1句话，15字内），像朋友聊天。"
  },
  "tts": {
    "voice_zh": "zh-CN-XiaoyiNeural",
    "voice_en": "en-US-JennyNeural",
    "rate": "+25%",
    "volume": "+0%",
    "pitch": "+5Hz",
    "cache_enabled": true
  },
  "audio": {
    "sample_rate": 16000,
    "channels": 1,
    "chunk_size": 1600,
    "device": "plughw:0,1"
  },
  "system": {
    "log_level": "INFO",
    "enable_monitoring": true,
    "enable_interrupt": true
  }
}