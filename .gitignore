# Git忽略文件配置
# Author: 哈雷酱(本小姐)

# ==================== 编译产物 ====================
# C/C++编译生成的文件
*.o
*.a
*.so
*.so.*
*.dylib
*.exe
*.out
simple_player

# ==================== Python ====================
# Python字节码
*.pyc
*.pyo
__pycache__/
*.py[cod]
*$py.class

# Python虚拟环境
venv/
env/
ENV/
.venv

# ==================== 音频文件 ====================
# 生成的音频文件
output/**/*.wav
output/**/*.mp3
output/**/*.pcm
output/*_temp.mp3
output/batch_*/
output/*.txt
output/recordings/

# 但保留output目录和README
!output/
!output/README.md

# ==================== 模型文件 ====================
# ONNX模型文件（太大，不提交到git）
*.onnx
# 但保留模型目录结构和配置文件
!models/
!models/**/
!models/**/*.txt
!models/**/*.json

# ==================== 临时文件 ====================
# 系统临时文件
*.tmp
*.temp
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# 编辑器临时文件
.vscode/
.idea/
*.sublime-*

# ==================== 日志文件 ====================
*.log
logs/

# ==================== 测试文件 ====================
# 测试脚本和文件
my_*.sh
test_*.sh
test_*.py

# 临时转换脚本
convert_*.sh
*sensevoice*.sh
integrate_*.sh
download_*.sh
set_*.sh

# ==================== 大型目录 ====================
# Sherpa-ONNX 源码目录（1.4GB）
sherpa-onnx/

# SenseVoice 模型代码（14MB）
SenseVoice/

# 编译产物目录
kernel_meta/

# ==================== 模型压缩包 ====================
# 模型压缩包（太大，不提交）
*.tar.bz2
*.tar.gz
*.zip

# ==================== Claude / IDE ====================
.claude/
.bmad-core/

# ==================== 其他 ====================
# 检查结果文件
check_result.json
fusion_result.json
